---
layout: default
---
<div class="post">
  {% assign archive_posts = page.posts %}
  {% if site.active_lang == site.default_lang %}
    {% assign default_lang_path = '/' | append: site.default_lang | append: '/' %}
    {% assign archive_posts = archive_posts | where_exp: 'post', 'post.path contains default_lang_path' %}
  {% endif %}
  <div class="post-header">
    <h1 class="post-title"><i class="fa-solid fa-hashtag fa-sm"></i> {{ page.title | strip_html | escape_once }}</h1>
    <p class="post-description">{{ site.data[site.active_lang].strings.archive_tag }}</p>
  </div>

  <article class="archive">
    <div class="table-responsive">
      <table class="table table-sm table-borderless">
        {% for post in archive_posts %}
          <tr>
            <th scope="row">{% include date_format.liquid format='short' date=post.date %}</th>
            <td>
              {% if post.redirect == blank %}
                <a class="post-link" href="{{ post.url | relative_url }}">{{ post.title | strip_html | escape_once }}</a>
              {% elsif post.redirect contains '://' %}
                <a class="post-link" href="{{ post.redirect }}" target="_blank" rel="noopener noreferrer">
                  {{- post.title | strip_html | escape_once -}}
                </a>
              {% else %}
                <a class="post-link" href="{{ post.redirect | relative_url }}">{{ post.title | strip_html | escape_once }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  </article>
</div>
