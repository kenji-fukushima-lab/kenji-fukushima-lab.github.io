{% capture author_name %}{{ site.first_name }}{% if site.middle_name %} {{ site.middle_name }}{% endif %} {{ site.last_name }}{% endcapture %}
{% assign feed_lang = page.feed_lang | default: site.active_lang %}
{% assign feed_posts = site.data.generated_posts_by_lang[feed_lang] %}
{% if feed_posts == null %}
  {% assign feed_posts = '' | split: '' %}
{% endif %}
{% assign localized_feed_path = page.url | replace: 'index.html', '' %}
{% assign localized_home_path = '/' %}
{% if feed_lang != site.default_lang %}
  {% assign localized_home_path = '/' | prepend: feed_lang | prepend: '/' %}
{% endif %}
{% assign xml_declaration = '<?xml version="1.0" encoding="utf-8"?>' %}
{{ xml_declaration }}
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ feed_lang }}">
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <link href="{{ localized_feed_path | absolute_url }}" rel="self" type="application/atom+xml">
  <link href="{{ localized_home_path | absolute_url }}" rel="alternate" type="text/html" hreflang="{{ feed_lang }}">
  <updated>
    {%- if feed_posts.size > 0 %}{{ feed_posts.first.updated }}{% else %}{{ site.time | date_to_xmlschema }}{% endif -%}
  </updated>
  <id>{{ localized_feed_path | absolute_url | xml_escape }}</id>
  <title type="html">{{ site.title | append: ' | ' | append: page.title | smartify | xml_escape }}</title>
  {% if page.description %}
    <subtitle>{{ page.description | xml_escape }}</subtitle>
  {% endif %}
  <author>
    <name>{{ author_name | xml_escape }}</name>
  </author>
  {% for post in feed_posts limit: 10 %}
    {% assign post_title = post.title | smartify | strip_html | normalize_whitespace | xml_escape %}
    <entry xml:lang="{{ feed_lang }}">
      <title type="html">{{ post_title }}</title>
      <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post_title }}">
      <published>{{ post.date }}</published>
      <updated>{{ post.updated }}</updated>
      <id>{{ post.url | absolute_url | xml_escape }}</id>
      <author>
        <name>{{ post.author | default: author_name | strip_html | normalize_whitespace | xml_escape }}</name>
      </author>
      {% for category in post.categories %}
        <category term="{{ category | xml_escape }}" />
      {% endfor %}
      {% for tag in post.tags %}
        <category term="{{ tag | xml_escape }}" />
      {% endfor %}
      {% assign post_summary = post.summary %}
      {% if post_summary and post_summary != empty %}
        <summary type="text">{{ post_summary | normalize_whitespace | xml_escape }}</summary>
      {% endif %}
    </entry>
  {% endfor %}
</feed>
