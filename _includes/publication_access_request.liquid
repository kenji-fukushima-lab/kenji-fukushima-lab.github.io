{% assign publication_access_is_ja = false %}
{% if site.active_lang == 'ja' %}
  {% assign publication_access_is_ja = true %}
{% endif %}
{% assign publication_access_config = site.data.publication_access %}

<section class="publication-access" aria-labelledby="publication-access-title">
  <div class="publication-access-copy">
    <p class="publication-access-kicker">
      {% if publication_access_is_ja %}論文ファイル{% else %}Publication files{% endif %}
    </p>
    <h2 id="publication-access-title">
      {% if publication_access_is_ja %}
        論文PDFの閲覧申請
      {% else %}
        Request access to publication files
      {% endif %}
    </h2>
    <p>
      {% if publication_access_is_ja %}
        当研究室では、<a
          href="https://researchmap.jp/kenji_fukushima/published_papers?lang=ja&amp;limit=100"
          target="_blank"
          rel="external noopener noreferrer"
          >researchmap</a
        >に論文のパスワード付きPDFコピーをアーカイブしています。これらのファイルへのアクセスを希望する方は、フォームから申請してください。
      {% else %}
        We archive password-protected PDF copies of our publications on
        <a
          href="https://researchmap.jp/kenji_fukushima/published_papers?lang=en&amp;limit=100"
          target="_blank"
          rel="external noopener noreferrer"
          >researchmap</a
        >. Those wishing to access these files are asked to complete the form and verify their email address.
      {% endif %}
    </p>
  </div>
  <button
    class="publication-access-button"
    type="button"
    data-publication-access-open
    aria-haspopup="dialog"
    aria-controls="publication-access-dialog"
  >
    {% if publication_access_is_ja %}アクセスを申請{% else %}Request access{% endif %}
  </button>
</section>

<dialog
  class="publication-access-dialog"
  id="publication-access-dialog"
  aria-labelledby="publication-access-dialog-title"
>
  <div class="publication-access-dialog-header">
    <div>
      <p class="publication-access-kicker">
        {% if publication_access_is_ja %}メール確認{% else %}Email verification{% endif %}
      </p>
      <h2 id="publication-access-dialog-title">
        {% if publication_access_is_ja %}論文PDFの閲覧申請{% else %}Request publication access{% endif %}
      </h2>
    </div>
    <button
      class="publication-access-close"
      type="button"
      data-publication-access-close
      aria-label="{% if publication_access_is_ja %}閉じる{% else %}Close{% endif %}"
    >
      <span aria-hidden="true">&times;</span>
    </button>
  </div>

  <form
    class="publication-access-form"
    action="{{ publication_access_config.web_app_url }}"
    method="post"
    target="_blank"
    rel="noopener"
    data-publication-access-form
  >
    <input name="form_started_at" type="hidden" value="" data-publication-access-started-at>

    <label>
      <span>
        {%- if publication_access_is_ja %}氏名{% else %}Full name{% endif -%}
      </span>
      <input name="name" type="text" autocomplete="name" minlength="2" maxlength="120" required>
    </label>

    <label>
      <span>
        {%- if publication_access_is_ja %}所属{% else %}Affiliation{% endif -%}
      </span>
      <input name="affiliation" type="text" autocomplete="organization" minlength="2" maxlength="200" required>
    </label>

    <label>
      <span>
        {%- if publication_access_is_ja %}メールアドレス{% else %}Email address{% endif -%}
      </span>
      <input name="email" type="email" autocomplete="email" maxlength="254" required>
    </label>

    <label class="publication-access-honeypot" aria-hidden="true">
      <span>Website</span>
      <input name="website" type="text" autocomplete="off" tabindex="-1">
    </label>

    <label class="publication-access-consent">
      <input name="consent" type="checkbox" value="yes" required>
      <span>
        {% if publication_access_is_ja %}
          論文ファイルを再配布せず、ダウンロードパスワードを他者と共有しないことに同意します。
        {% else %}
          I agree not to redistribute the publication files or share the download password with others.
        {% endif %}
      </span>
    </label>

    <p class="publication-access-form-note">
      {% if publication_access_is_ja %}
        送信後に届く英語のメールを開き、24時間以内にメールアドレスを確認してください。
      {% else %}
        After submitting, open the verification email and confirm your address within 24 hours.
      {% endif %}
    </p>

    <div class="publication-access-actions">
      <button class="publication-access-button publication-access-button-secondary" type="button" data-publication-access-close>
        {% if publication_access_is_ja %}キャンセル{% else %}Cancel{% endif %}
      </button>
      <button class="publication-access-button" type="submit">
        {% if publication_access_is_ja %}確認メールを送信{% else %}Send verification email{% endif %}
      </button>
    </div>
  </form>
</dialog>
