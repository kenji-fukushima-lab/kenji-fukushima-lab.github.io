{% assign network = site.data.paper_network %}
{% assign lang_code = include.lang | default: 'ja' %}

{% if lang_code == 'en' %}
  {% assign network_error_prefix = 'Failed to generate the paper network:' %}
  {% assign year_old_label = 'Earlier papers' %}
  {% assign year_new_label = 'Recent papers' %}
  {% assign node_example_1 = 'Connection score 1' %}
  {% assign node_example_2 = 'Connection score 4' %}
  {% assign node_example_3 = 'Connection score 8' %}
  {% assign edge_example_1 = 'Shared coauthors 1' %}
  {% assign edge_example_2 = 'Shared coauthors 2' %}
  {% assign edge_example_3 = 'Shared coauthors 3' %}
  {% assign note_text = 'Shared-author links exclude the lab head so the structure reflects recurring collaborator overlap.' %}
  {% assign fit_view_label = 'Fit view' %}
  {% assign zoom_in_label = 'Zoom in' %}
  {% assign zoom_out_label = 'Zoom out' %}
  {% assign toolbar_note = 'Drag the background to pan and use the mouse wheel to zoom.' %}
  {% assign search_label = 'Highlight paper' %}
  {% assign search_placeholder = 'e.g. Cephalotus' %}
  {% assign year_range_label = 'Publication year range' %}
  {% assign min_weight_label = 'Minimum shared coauthors shown' %}
  {% assign min_weight_value = '1+' %}
  {% assign hide_isolates_label = 'Hide isolated papers' %}
  {% assign author_list_label = 'Papers' %}
  {% assign paper_col = 'Paper' %}
  {% assign year_col = 'Year' %}
  {% assign connections_col = 'Links' %}
  {% assign score_col = 'Connection score' %}
{% else %}
  {% assign network_error_prefix = '論文ネットワークを生成できませんでした:' %}
  {% assign year_old_label = '古い論文' %}
  {% assign year_new_label = '新しい論文' %}
  {% assign node_example_1 = '接続スコア 1' %}
  {% assign node_example_2 = '接続スコア 4' %}
  {% assign node_example_3 = '接続スコア 8' %}
  {% assign edge_example_1 = '共通著者 1人' %}
  {% assign edge_example_2 = '共通著者 2人' %}
  {% assign edge_example_3 = '共通著者 3人' %}
  {% assign note_text = '論文間のリンク計算では研究室主宰者を除外し、繰り返し重なる共同研究体制が見えるようにしています。' %}
  {% assign fit_view_label = '全体表示' %}
  {% assign zoom_in_label = '拡大' %}
  {% assign zoom_out_label = '縮小' %}
  {% assign toolbar_note = '背景をドラッグして移動、ホイールで拡大縮小できます。' %}
  {% assign search_label = '論文タイトルをハイライト' %}
  {% assign search_placeholder = '例: Cephalotus' %}
  {% assign year_range_label = '出版年範囲' %}
  {% assign min_weight_label = '表示する最小共通著者数' %}
  {% assign min_weight_value = '1人以上' %}
  {% assign hide_isolates_label = '孤立した論文を隠す' %}
  {% assign author_list_label = '論文一覧' %}
  {% assign paper_col = '論文' %}
  {% assign year_col = '年' %}
  {% assign connections_col = '接続数' %}
  {% assign score_col = '接続スコア' %}
{% endif %}

{% if network.error %}
  <div class="alert alert-warning" role="alert">
    {{ network_error_prefix }} {{ network.error }}
  </div>
{% else %}
  {% assign stats = network.stats %}
  <div class="paper-network-page">
    <section class="paper-network-supporting">
      <aside class="paper-network-legend">
        <div class="paper-network-legend-grid">
          <ul>
            <li><span class="paper-network-year-node"></span><span>{{ year_old_label }}</span><span>{{ stats.year_first }}</span></li>
            <li><span class="paper-network-year-node paper-network-year-node-recent"></span><span>{{ year_new_label }}</span><span>{{ stats.year_last }}</span></li>
          </ul>
          <div class="paper-network-graphic-legend">
            <div>
              <ul>
                <li><span class="paper-graphic-node-size"><span class="paper-graphic-node paper-graphic-node-sm"></span>{{ node_example_1 }}</span></li>
                <li><span class="paper-graphic-node-size"><span class="paper-graphic-node paper-graphic-node-mid"></span>{{ node_example_2 }}</span></li>
                <li><span class="paper-graphic-node-size"><span class="paper-graphic-node paper-graphic-node-lg"></span>{{ node_example_3 }}</span></li>
              </ul>
            </div>
            <div>
              <ul>
                <li><span class="paper-graphic-edge-size"><span class="paper-graphic-edge paper-graphic-edge-sm"></span>{{ edge_example_1 }}</span></li>
                <li><span class="paper-graphic-edge-size"><span class="paper-graphic-edge paper-graphic-edge-md"></span>{{ edge_example_2 }}</span></li>
                <li><span class="paper-graphic-edge-size"><span class="paper-graphic-edge paper-graphic-edge-lg"></span>{{ edge_example_3 }}</span></li>
              </ul>
            </div>
          </div>
        </div>
        <p class="paper-network-note">{{ note_text }}</p>
      </aside>
    </section>

    <section class="paper-network-layout">
      <div class="paper-network-graph-panel">
        <div class="paper-network-toolbar" aria-label="{{ toolbar_note }}">
          <button id="paper-network-fit-view" class="btn btn-sm btn-outline-primary" type="button">{{ fit_view_label }}</button>
          <button id="paper-network-zoom-in" class="btn btn-sm btn-outline-primary" type="button">{{ zoom_in_label }}</button>
          <button id="paper-network-zoom-out" class="btn btn-sm btn-outline-primary" type="button">{{ zoom_out_label }}</button>
          <span class="paper-network-toolbar-note">{{ toolbar_note }}</span>
        </div>
        <div id="paper-network-graph"></div>
      </div>
    </section>

    <section class="paper-network-controls">
      <div class="paper-network-controls-grid">
        <div>
          <label for="paper-network-search">{{ search_label }}</label>
          <input id="paper-network-search" type="search" placeholder="{{ search_placeholder }}">
        </div>
        <div>
          <label for="paper-network-year-min">{{ year_range_label }}</label>
          <div class="paper-network-year-range" id="paper-network-year-range" style="--range-min: 0%; --range-max: 100%;">
            <div class="paper-network-year-range-values">
              <span id="paper-network-year-min-value">{{ stats.year_first }}</span>
              <span id="paper-network-year-max-value">{{ stats.year_last }}</span>
            </div>
            <div class="paper-network-year-range-slider">
              <div class="paper-network-year-range-track"></div>
              <input id="paper-network-year-min" type="range" min="{{ stats.year_first }}" max="{{ stats.year_last }}" value="{{ stats.year_first }}" aria-label="{{ year_range_label }}">
              <input id="paper-network-year-max" type="range" min="{{ stats.year_first }}" max="{{ stats.year_last }}" value="{{ stats.year_last }}" aria-label="{{ year_range_label }}">
            </div>
          </div>
        </div>
        <div>
          <label for="paper-network-min-weight">{{ min_weight_label }}</label>
          <input id="paper-network-min-weight" type="range" min="1" max="{{ stats.max_edge_weight | at_least: 1 | at_most: 6 }}" value="1">
          <small id="paper-network-min-weight-value">{{ min_weight_value }}</small>
        </div>
        <div>
          <label class="paper-network-inline-toggle" for="paper-network-hide-isolates">
            <input id="paper-network-hide-isolates" type="checkbox" checked>
            {{ hide_isolates_label }}
          </label>
        </div>
      </div>
      <p id="paper-network-filter-summary" aria-live="polite"></p>
    </section>

    <details class="paper-network-table">
      <summary>{{ author_list_label }}</summary>
      <div class="table-responsive">
        <table class="table table-sm">
          <thead>
            <tr>
              <th>{{ paper_col }}</th>
              <th>{{ year_col }}</th>
              <th>{{ connections_col }}</th>
              <th>{{ score_col }}</th>
            </tr>
          </thead>
          <tbody>
            {% for paper in network.top_papers %}
              <tr data-paper-id="{{ paper.id }}">
                <td>
                  {% if paper.url %}
                    <a href="{{ paper.url }}" target="_blank" rel="noopener noreferrer">{{ paper.title }}</a>
                  {% else %}
                    {{ paper.title }}
                  {% endif %}
                </td>
                <td class="paper-year">{{ paper.year }}</td>
                <td class="paper-degree">{{ paper.shared_author_degree }}</td>
                <td class="paper-score">{{ paper.shared_author_weight_sum }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </details>
  </div>

  <script id="paper-network-data" type="application/json">{{ network | jsonify }}</script>
  <script id="paper-network-i18n" type="application/json">{"lang":"{{ lang_code }}","unavailable":"{% if lang_code == 'en' %}Network data is unavailable.{% else %}Network data is unavailable.{% endif %}","graphAriaLabel":"{% if lang_code == 'en' %}Paper network graph{% else %}論文ネットワーク図{% endif %}","filterSummary":"{% if lang_code == 'en' %}Visible: {papers} of {totalPapers} papers / {links} links / {minYear}-{maxYear}{% else %}表示中: 総論文数{totalPapers}本中{papers}本 / リンク{links}本 / {minYear}-{maxYear}年{% endif %}","minWeightValue":"{% if lang_code == 'en' %}{value}+{% else %}{value}人以上{% endif %}","detailYear":"{% if lang_code == 'en' %}Year{% else %}年{% endif %}","detailAuthors":"{% if lang_code == 'en' %}Authors{% else %}著者{% endif %}","detailConnections":"{% if lang_code == 'en' %}Linked papers{% else %}接続論文数{% endif %}","detailScore":"{% if lang_code == 'en' %}Connection score{% else %}接続スコア{% endif %}","detailSharedAuthors":"{% if lang_code == 'en' %}Shared coauthors (excluding Kenji Fukushima){% else %}共通著者（Kenji Fukushima を除く）{% endif %}","noSharedAuthors":"{% if lang_code == 'en' %}None{% else %}なし{% endif %}","linkSharedAuthors":"{% if lang_code == 'en' %}Shared coauthors{% else %}共通著者{% endif %}","na":"n/a"}</script>
{% endif %}