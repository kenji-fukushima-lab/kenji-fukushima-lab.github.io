{% assign repo_parts = include.repository | split: '/' %}
{% assign username = repo_parts.first %}
{% assign repo_name = repo_parts.last %}
{% assign fallback_about = site.data.repo_about[include.repository] | default: '' %}
{% if site.active_lang == 'ja' %}
  {% capture repo_stars_aria_label %}{{ include.repository }} のスター一覧を開く{% endcapture %}
  {% capture repo_forks_aria_label %}{{ include.repository }} のフォーク一覧を開く{% endcapture %}
  {% capture repo_commits_aria_label %}{{ include.repository }} のコミット履歴を開く{% endcapture %}
  {% capture repo_issues_aria_label %}{{ include.repository }} の Issue を開く{% endcapture %}
  {% assign repo_stars_tooltip = 'Stars' %}
  {% assign repo_forks_tooltip = 'Forks' %}
  {% assign repo_commits_tooltip = 'Last commit' %}
  {% assign repo_issues_tooltip = 'Issue' %}
{% else %}
  {% capture repo_stars_aria_label %}Open stargazers for {{ include.repository }}{% endcapture %}
  {% capture repo_forks_aria_label %}Open forks for {{ include.repository }}{% endcapture %}
  {% capture repo_commits_aria_label %}Open commit history for {{ include.repository }}{% endcapture %}
  {% capture repo_issues_aria_label %}Open issues for {{ include.repository }}{% endcapture %}
  {% assign repo_stars_tooltip = 'Stars' %}
  {% assign repo_forks_tooltip = 'Forks' %}
  {% assign repo_commits_tooltip = 'Last commit' %}
  {% assign repo_issues_tooltip = 'Issues' %}
{% endif %}

<div class="repo repo-compact">
  <div class="repo-compact-main">
    <a
      class="repo-compact-title external-link-track"
      href="https://github.com/{{ include.repository }}"
      rel="external nofollow noopener noreferrer"
      target="_blank"
      aria-label="Open {{ include.repository }} on GitHub"
      data-analytics-label="repository_home"
    >
      <svg height="20" width="20" viewBox="0 0 16 16" fill="var(--global-theme-color)" aria-hidden="true">
        <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z"></path>
      </svg>
      <span class="repo-compact-name">{{ username }}/{{ repo_name }}</span>
    </a>
    <span
      class="repo-compact-about{% if fallback_about == '' %} is-empty{% endif %}"
      data-repo-about="{{ include.repository }}"
      data-repo-about-default="{{ fallback_about | escape }}"
      {% if fallback_about != '' %}
        title="{{ fallback_about }}"
      {% endif %}
      aria-live="polite"
    >
      {{ fallback_about }}
    </span>
  </div>

  <div class="repo-compact-badges">
    <a
      href="https://github.com/{{ include.repository }}/stargazers"
      rel="external nofollow noopener noreferrer"
      target="_blank"
      class="external-link-track"
      data-toggle="tooltip"
      title="{{ repo_stars_tooltip }}"
      aria-label="{{ repo_stars_aria_label | strip }}"
      data-analytics-label="repository_stargazers"
    >
      <span
        class="repo-compact-stat repo-compact-stat-stars is-loading"
        data-repo-stat="stars"
        data-repo-stat-repository="{{ include.repository }}"
        aria-hidden="true"
      >
        <svg height="14" width="14" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.719-4.194-3.046-2.97a.75.75 0 0 1 .416-1.278l4.21-.612L7.327.668A.75.75 0 0 1 8 .25Z"></path>
        </svg>
        <span class="repo-compact-stat-label">{{ repo_stars_tooltip }}</span>
        <span class="repo-compact-stat-value" data-repo-stat-value>--</span>
      </span>
    </a>
    <a
      href="https://github.com/{{ include.repository }}/network/members"
      rel="external nofollow noopener noreferrer"
      target="_blank"
      class="external-link-track"
      data-toggle="tooltip"
      title="{{ repo_forks_tooltip }}"
      aria-label="{{ repo_forks_aria_label | strip }}"
      data-analytics-label="repository_forks"
    >
      <span
        class="repo-compact-stat repo-compact-stat-forks is-loading"
        data-repo-stat="forks"
        data-repo-stat-repository="{{ include.repository }}"
        aria-hidden="true"
      >
        <svg height="14" width="14" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M5 5.25a2.25 2.25 0 1 1 3 2.122v2.378A2.25 2.25 0 0 0 10.25 12h1.5A2.25 2.25 0 0 0 14 9.75V7.372a2.25 2.25 0 1 1 1.5 0V9.75a3.75 3.75 0 0 1-3.75 3.75h-1.5A3.75 3.75 0 0 1 6.5 9.75V7.372A2.25 2.25 0 0 1 5 5.25Zm9 0a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Zm-9.75 0a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z"></path>
        </svg>
        <span class="repo-compact-stat-label">{{ repo_forks_tooltip }}</span>
        <span class="repo-compact-stat-value" data-repo-stat-value>--</span>
      </span>
    </a>
    <a
      href="https://github.com/{{ include.repository }}/commits/main"
      rel="external nofollow noopener noreferrer"
      target="_blank"
      class="external-link-track"
      data-toggle="tooltip"
      title="{{ repo_commits_tooltip }}"
      aria-label="{{ repo_commits_aria_label | strip }}"
      data-analytics-label="repository_commits"
    >
      <span
        class="repo-compact-stat repo-compact-stat-commits is-loading"
        data-repo-stat="commits"
        data-repo-stat-repository="{{ include.repository }}"
        aria-hidden="true"
      >
        <svg height="14" width="14" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M1.643 3.143 3.427.427A.25.25 0 0 1 3.886.56l.286 2.652a6.5 6.5 0 1 1-1.18 5.458.75.75 0 1 1 1.43-.448 5.001 5.001 0 1 0 1.015-4.874l2.708.293a.25.25 0 0 1 .133.459L5.562 5.883a.25.25 0 0 1-.346-.07L3.573 3.489a.25.25 0 0 1 .07-.346ZM8.75 5.75v2.992l2.028 1.216a.75.75 0 1 1-.771 1.286l-2.397-1.44A.75.75 0 0 1 7.25 9.16V5.75a.75.75 0 0 1 1.5 0Z"></path>
        </svg>
        <span class="repo-compact-stat-label">{{ repo_commits_tooltip }}</span>
        <span class="repo-compact-stat-value" data-repo-stat-value>--</span>
      </span>
    </a>
    <a
      href="https://github.com/{{ include.repository }}/issues"
      rel="external nofollow noopener noreferrer"
      target="_blank"
      class="external-link-track"
      data-toggle="tooltip"
      title="{{ repo_issues_tooltip }}"
      aria-label="{{ repo_issues_aria_label | strip }}"
      data-analytics-label="repository_issues"
    >
      <span
        class="repo-compact-stat repo-compact-stat-issues is-loading"
        data-repo-stat="issues"
        data-repo-stat-repository="{{ include.repository }}"
        aria-hidden="true"
      >
        <svg height="14" width="14" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M8 1.5a6.5 6.5 0 1 1 0 13 6.5 6.5 0 0 1 0-13ZM8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0Zm.75 4.75a.75.75 0 0 0-1.5 0v3.5a.75.75 0 0 0 1.5 0v-3.5ZM8 11a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z"></path>
        </svg>
        <span class="repo-compact-stat-label">{{ repo_issues_tooltip }}</span>
        <span class="repo-compact-stat-value" data-repo-stat-value>--</span>
      </span>
    </a>
  </div>
</div>
